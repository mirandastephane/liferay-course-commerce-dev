: 40px 48px 36px;\n  border-radius: 15px;\n  margin: 24px 24px 0;\n  position: relative;\n  overflow: hidden;\n}\n\n.cvs-terms-doc .page-header::before {\n  content: '''';\n  position: absolute;\n  top: -60px;\n  right: -60px;\n  width: 220px;\n  height: 220px;\n  border-radius: 50%;\n  background: rgba(255,255,255,0.06);\n  pointer-events: none;\n}\n\n.cvs-terms-doc .page-header::after {\n  content: '''';\n  position: absolute;\n  bottom: -40px;\n  right: 80px;\n  width: 140px;\n  height: 140px;\n  border-radius: 50%;\n  background: rgba(255,255,255,0.04);\n  pointer-events: none;\n}\n\n.cvs-terms-doc .page-header .eyebrow {\n  font-size: 0.72rem;\n  font-weight: 700;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: rgba(255,255,255,0.65);\n  margin-bottom: 10px;\n}\n\n.cvs-terms-doc .page-header h1 {\n  font-size: 24px;\n  font-weight: 600;\n  letter-spacing: -0.02em;\n  line-height: 1.2;\n  color: #fff;\n  margin: 0;\n  padding: 0;\n  border: none;\n  text-transform: none;\n}\n\n.cvs-terms-doc .page-header .meta {\n  font-size: 0.78rem;\n  color: rgba(255,255,255,0.6);\n  margin-top: 14px;\n}\n\n/* CONTAINER */\n.cvs-terms-doc .container {\n  max-width: 760px;\n  margin: 0 auto;\n  padding: 40px 24px 80px;\n}\n\n/* NOTICE */\n.cvs-terms-doc .notice {\n  background: #e6f4f4;\n  border-left: 4px solid #1d8c8c;\n  padding: 16px 20px;\n  margin-bottom: 40px;\n  font-size: 0.875rem;\n  color: #155f5f;\n  line-height: 1.6;\n  border-radius: 0 8px 8px 0;\n}\n\n/* SECTIONS */\n.cvs-terms-doc .container h2 {\n  font-size: 18px;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: #1d8c8c;\n  margin-top: 40px;\n  margin-bottom: 12px;\n  padding-bottom: 8px;\n  border-bottom: 1px solid #d4e8e8;\n}\n\n.cvs-terms-doc .container p {\n  margin-bottom: 16px;\n  font-size: 16px;\n  color: #444;\n  line-height: 1.8;\n}\n\n.cvs-terms-doc .container ul {\n  margin: 0 0 16px 0;\n  font-size: 16px;\n  color: #444;\n  list-style: none;\n  padding: 0;\n}\n\n.cvs-terms-doc .container ul li {\n  margin-bottom: 8px;\n  padding-left: 20px;\n  position: relative;\n  line-height: 1.7;\n}\n\n.cvs-terms-doc .container ul li::before {\n  content: '''';\n  position: absolute;\n  left: 0;\n  top: 10px;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: #1d8c8c;\n  opacity: 0.6;\n}\n\n/* FOOTER */\n.cvs-terms-doc .footer {\n  margin-top: 60px;\n  padding-top: 24px;\n  border-top: 1px solid #d4e8e8;\n  font-size: 0.78rem;\n  color: #999;\n}\n\n.cvs-terms-doc .footer strong {\n  color: #1d8c8c;\n}\n\n\n.cvs-terms-doc .plan-badge {\n  display: inline-block;\n  background: #2a6fa8;\n  color: #fff;\n  font-size: 0.65rem;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  padding: 3px 11px;\n  border-radius: 20px;\n  margin-left: 10px;\n  vertical-align: middle;\n  position: relative;\n  top: -3px;\n}\n<\/style>\n<\/head>\n<body>\n<div class=\"cvs-terms-doc\">\n<div class=\"page-header\">\n    <div class=\"eyebrow\">Clarity Vision Solutions \u005cu2014 Service Plan<\/div>\n    <h1>Artisan Protection Plan<br><span class=\"plan-badge\">STANDARD<\/span>\n    \u005cu2014 Terms &amp; Conditions<\/h1>\n    <div class=\"meta\">Effective Date: January 1, 2026 &nbsp;\u00b7&nbsp; Version 1.0<\/div>\n  <\/div>\n\n  <div class=\"container\">\n\n    <div class=\"notice\">\n      Please read these terms carefully before activating your Service Plan. By purchasing or activating the Artisan Protection Plan \u005cu2014 Standard, you agree to be bound by the terms set forth below.\n    <\/div>\n\n    <h2>1. Coverage Overview<\/h2>\n    <p>The Artisan Protection Plan \u005cu2014 Standard provides comprehensive repair and replacement coverage for eligible Clarity Vision Solutions eyewear products purchased through authorized channels. Coverage begins on the date of product purchase and remains active for the duration specified in your plan.<\/p>\n    <p>Coverage Duration: <strong>24 months<\/strong> from the date of purchase.<\/p>\n\n    <h2>2. What Is Covered<\/h2>\n    <ul>\n      <li>Manufacturing defects in frames and lenses under normal use conditions.<\/li>\n      <li>Accidental damage including scratches, frame breakage, lens damage, and hinge failure.<\/li>\n      <li>Up to five (5) covered repair or replacement events per plan term.<\/li>\n      <li>Standard lens cleaning and adjustment services at authorized Clarity service centers.<\/li>\n    <\/ul>\n\n    <h2>3. What Is Not Covered<\/h2>\n    <ul>\n      <li>Loss or theft of the product.<\/li>\n      <li>Damage resulting from misuse, neglect, or unauthorized modifications.<\/li>\n      <li>Prescription lens changes due to changes in vision.<\/li>\n      <li>Damage caused by exposure to extreme heat, chemicals, or corrosive environments.<\/li>\n    <\/ul>\n\n    <h2>4. Claims Process<\/h2>\n    <p>To submit a claim, contact Clarity Vision Solutions customer support through your account portal or visit an authorized service center. Claims must be submitted within the active coverage period. A maximum of <strong>five (5) claims<\/strong> may be submitted per plan term. The maximum claim value covered under this plan is <strong>$500.00 USD<\/strong> per claim.<\/p>\n    <p>Clarity reserves the right to repair or replace the covered item at its sole discretion. Replacement products may be of equal or comparable value. In cases where repair is not feasible, a replacement of equivalent specification will be provided.<\/p>\n\n    <h2>5. Grace Period<\/h2>\n    <p>A grace period of <strong>60 days<\/strong> applies following the expiration of this plan. Claims submitted during the grace period for damage or defects that occurred during the active coverage term will be honored subject to review.<\/p>\n\n    <h2>6. Underwriter<\/h2>\n    <p>Coverage under this plan is underwritten by <strong>ClearShield Insurance Ltd.<\/strong>, an authorized insurance provider. Claims are subject to the underwriter''s review and approval process. Clarity Vision Solutions acts as the plan administrator on behalf of the underwriter.<\/p>\n\n    <h2>7. Transferability<\/h2>\n    <p>This plan is non-transferable and applies solely to the original purchaser of the covered product. It may not be assigned, sold, or otherwise transferred to any third party.<\/p>\n\n    <h2>8. Limitation of Liability<\/h2>\n    <p>Clarity Vision Solutions'' and ClearShield Insurance Ltd.''s combined total liability under this plan shall not exceed the original purchase price of the covered product multiplied by the number of remaining covered events. To the fullest extent permitted by applicable law, implied warranties are disclaimed.<\/p>\n\n    <h2>9. Governing Law<\/h2>\n    <p>These terms shall be governed by and construed in accordance with the laws of the State of California, without regard to its conflict of law provisions.<\/p>\n\n    <h2>10. Amendments<\/h2>\n    <p>Clarity Vision Solutions reserves the right to amend these terms at any time with reasonable notice. Continued use of the plan following notice of changes constitutes acceptance of the revised terms.<\/p>\n\n    <div class=\"footer\">\n      &copy; 2026 Clarity Vision Solutions. All rights reserved. &nbsp;\u00b7&nbsp; For questions, contact <strong>support@clarityvisionsolutions.com<\/strong>\n    <\/div>\n\n  <\/div>\n<\/div>\n<\/body>\n<\/html>","config":{}}}}','xyoe',0,'BASIC_COMPONENT-html',1,'2026-06-19 22:50:37.308000',NULL)
