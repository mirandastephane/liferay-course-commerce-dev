display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n\n    .cvs-legal .plan-card .meta span::before {\n      content: '''';\n      display: inline-block;\n      width: 6px;\n      height: 6px;\n      border-radius: 50%;\n      background: #1d8c8c;\n      opacity: 0.5;\n      flex-shrink: 0;\n    }\n\n    .cvs-legal .plan-card .btn {\n      display: block;\n      text-align: center;\n      padding: 9px 16px;\n      border-radius: 8px;\n      font-size: 13px;\n      font-weight: 600;\n      text-decoration: none;\n      border: 1.5px solid #1d8c8c;\n      color: #1d8c8c;\n      transition: background 0.15s, color 0.15s;\n    }\n\n    .cvs-legal .plan-card .btn:hover {\n      background: #1d8c8c;\n      color: #fff;\n    }\n\n    @media (max-width: 600px) {\n      .cvs-legal .plans-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n  <\/style>\n<\/head>\n<body>\n<div class=\"cvs-legal\">\n\n  <div class=\"legal-header\">\n    <div class=\"eyebrow\">Clarity Vision Solutions<\/div>\n    <h1>Artisan Protection Plans<\/h1>\n    <p>Select your plan below to review the full terms &amp; conditions.<\/p>\n  <\/div>\n\n  <hr class=\"divider\" />\n\n  <div class=\"plans-grid\">\n\n    <div class=\"plan-card basic\">\n      <span class=\"badge\">Basic<\/span>\n      <h2>Artisan Protection Plan \u005cu2014 Basic<\/h2>\n      <div class=\"meta\">\n        <span>12-month coverage<\/span>\n        <span>1 replacement event<\/span>\n        <span>Up to $250.00 per claim<\/span>\n        <span>30-day grace period<\/span>\n      <\/div>\n      <a href=\"/web/clarity/basic-plan-terms\" class=\"btn\">View Terms<\/a>\n    <\/div>\n\n    <div class=\"plan-card standard\">\n      <span class=\"badge\">Standard<\/span>\n      <h2>Artisan Protection Plan \u005cu2014 Standard<\/h2>\n      <div class=\"meta\">\n        <span>24-month coverage<\/span>\n        <span>Up to 5 replacement events<\/span>\n        <span>Up to $500.00 per claim<\/span>\n        <span>60-day grace period<\/span>\n      <\/div>\n      <a href=\"/web/clarity/standard-plan-terms\" class=\"btn\">View Terms<\/a>\n    <\/div>\n\n    <div class=\"plan-card premium\">\n      <span class=\"badge\">Premium<\/span>\n      <h2>Artisan Protection Plan \u005cu2014 Premium<\/h2>\n      <div class=\"meta\">\n        <span>24-month coverage<\/span>\n        <span>Unlimited replacement events<\/span>\n        <span>Up to $1,000.00 per claim<\/span>\n        <span>90-day grace period<\/span>\n      <\/div>\n      <a href=\"/web/clarity/premium-plan-terms\" class=\"btn\">View Terms<\/a>\n    <\/div>\n\n  <\/div>\n\n<\/div>\n<\/body>\n<\/html>\n","config":{}}}}','fuyj',0,'BASIC_COMPONENT-html',1,'2026-06-19 22:50:37.298000',NULL)
